# Regex search mode is required: the Insight source names differ between JVM and
# native isolate runs (truffle:<hash>/fooMain.js vs. foo from file:.../baz.mjs).
> if [ -z "${GRAALVM_VERSION}" ]
>   echo GRAALVM_VERSION must be set by the all tests job
>   exit 1
> fi
> if [ -z "${GRAALVM_MAVEN_REPO_URL}" -a -n "${GRAALVM_MAVEN_REPO}" ]
>   export GRAALVM_MAVEN_REPO_URL=file://${GRAALVM_MAVEN_REPO}
> fi
> if [ -z "${GRAALVM_MAVEN_REPO_URL}" ]
>   echo GRAALVM_MAVEN_REPO_URL must be set by the all tests job
>   exit 1
> fi
> export MAVEN_ARGS="--batch-mode -q -Dmaven.repo.local=${TMP_DIR}/mvn/agentscript-agent-embedding-symlinks -Dgraalvm.maven.repository=${GRAALVM_MAVEN_REPO_URL} -Dgraalvm.version=${GRAALVM_VERSION}-SNAPSHOT"
> export MAVEN_OPTS="${SUN_MISC_UNSAFE_OPTION} --enable-native-access=ALL-UNNAMED"
> mvn ${MAVEN_ARGS} package dependency:build-classpath -Dmdep.outputFile=${TMP_DIR}/agentscript-agent-embedding-symlinks.classpath
> export EMBEDDING_SYMLINKS_CP=${TEST_DIR}/target/classes:`cat ${TMP_DIR}/agentscript-agent-embedding-symlinks.classpath`
>[0r] ${JAVA_HOME}/bin/java ${SUN_MISC_UNSAFE_OPTION} --enable-native-access=ALL-UNNAMED -ea -cp ${EMBEDDING_SYMLINKS_CP} EmbeddingSymlinks ${TMP_DIR}
