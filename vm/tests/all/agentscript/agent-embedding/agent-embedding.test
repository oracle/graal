# Embedding replacement for the former tests/all/agentscript/agent-embedding.test.
# Embedding/EmbeddingDoubled/EmbeddingMoreContexts are plain polyglot embedders.
# EmbeddingRegisterSymbols relies on the EmbRegisterSymbolInstrument Truffle
# instrument, which is compiled (via the Truffle DSL processor) into target/classes
# and discovered from the application class path instead of the legacy
# -Dtruffle.class.path.append / --module-path mechanisms exercised previously.
> if [ -z "${GRAALVM_VERSION}" ]
>   echo GRAALVM_VERSION must be set by the all tests job
>   exit 1
> fi
> if [ -z "${GRAALVM_MAVEN_REPO_URL}" -a -n "${GRAALVM_MAVEN_REPO}" ]
>   export GRAALVM_MAVEN_REPO_URL=file://${GRAALVM_MAVEN_REPO}
> fi
> if [ -z "${GRAALVM_MAVEN_REPO_URL}" ]
>   echo GRAALVM_MAVEN_REPO_URL must be set by the all tests job
>   exit 1
> fi
> mvn ${MAVEN_ARGS} package dependency:build-classpath -Dmdep.outputFile=${TMP_DIR}/agentscript-agent-embedding.classpath
> export EMBEDDING_CP=${TEST_DIR}/target/classes:`cat ${TMP_DIR}/agentscript-agent-embedding.classpath`
>[0] ${JAVA_HOME}/bin/java ${SUN_MISC_UNSAFE_OPTION} --enable-native-access=ALL-UNNAMED -ea -cp ${EMBEDDING_CP} Embedding
Everything is OK!
