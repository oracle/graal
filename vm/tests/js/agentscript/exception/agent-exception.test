> js ../strip-license.js -- agent-exception.js > ${TMP_DIR}/agent-exception.js
> js ../strip-license.js -- log.js > ${TMP_DIR}/log.js
> for f in agent-error.js agent-error3.js agent-error4.js agent-error5.js agent-error6.js
>   js ../strip-license.js -- $f > ${TMP_DIR}/$f
> done
> cd ${TMP_DIR}
# The original test ran several commands twice, with and without --jvm, on the
# full GraalVM. On a standalone the mode is selected by the distribution under
# test (${MODE} is exported by the test harness based on its --type argument).
